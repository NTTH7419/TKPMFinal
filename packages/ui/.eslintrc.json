{
  "extends": ["../../.eslintrc.json"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "env": {
    "browser": true,
    "es2022": true
  },
  "ignorePatterns": ["dist/", "node_modules/", "dev/", "*.config.ts", "*.setup.ts", "scripts/"]
}
